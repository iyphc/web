<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
    <session-factory>
        <property name="hibernate.connection.driver_class">org.hsqldb.jdbc.JDBCDriver</property>
        <property name="hibernate.connection.url">jdbc:hsqldb:file:data/car_dealership;shutdown=true</property>
        <property name="hibernate.connection.username">sa</property>
        <property name="hibernate.connection.password"></property>
        <property name="hibernate.dialect">org.hibernate.dialect.HSQLDialect</property>
        <property name="hibernate.hbm2ddl.auto">none</property>
        <property name="hibernate.show_sql">false</property>

        <mapping class="ru.msu.cmc.webprac.entities.CarBrand"/>
        <mapping class="ru.msu.cmc.webprac.entities.Car"/>
        <mapping class="ru.msu.cmc.webprac.entities.Client"/>
        <mapping class="ru.msu.cmc.webprac.entities.Order"/>
        <mapping class="ru.msu.cmc.webprac.entities.OrderRequirement"/>
        <mapping class="ru.msu.cmc.webprac.entities.TestDrive"/>
    </session-factory>
</hibernate-configuration>
